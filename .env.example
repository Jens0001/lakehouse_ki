# ============================================
# Lakehouse KI - Environment Configuration
# ============================================
# Kopiere diese Datei als .env und passe die Werte an:
#   cp .env.example .env
#
# WICHTIG: .env niemals in Git committen!

# ============================================
# Netzwerk-Konfiguration
# ============================================
# Hostname/IP für Browser-Zugriff von externen Geräten.
# - localhost:     Zugriff nur vom selben Rechner (Default)
# - 192.168.x.y:  Zugriff von anderen Geräten im LAN
# - mein-server:   DNS-Name (wenn vorhanden)
# Automatische Erkennung: ./start.sh setzt den Wert beim Start.
EXTERNAL_HOST=localhost

# ============================================
# MinIO Configuration
# ============================================
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123

# ============================================
# Postgres Configuration
# ============================================
POSTGRES_USER=airflow
POSTGRES_PASSWORD=airflow123

# ============================================
# Keycloak Configuration
# ============================================
KEYCLOAK_URL=http://localhost:8082
KEYCLOAK_REALM=lakehouse
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=admin123
KEYCLOAK_DB_USER=keycloak
KEYCLOAK_DB_PASSWORD=keycloak123

# ============================================
# Keycloak OIDC Client Secrets (MinIO)
# ============================================
# Client Secret aus Keycloak Admin Console → Realm lakehouse → Clients → minio → Credentials
# Wird automatisch via Realm-Import gesetzt (init-scripts/keycloak/lakehouse-realm.json)
KEYCLOAK_CLIENT_ID_MINIO=minio
KEYCLOAK_CLIENT_SECRET_MINIO=CHANGE_ME_minio_client_secret

# ============================================
# Keycloak OIDC Client Secrets (Trino)
# ============================================
KEYCLOAK_CLIENT_ID_TRINO=trino
KEYCLOAK_CLIENT_SECRET_TRINO=CHANGE_ME_trino_client_secret

# ============================================
# Keycloak OIDC Client Secrets (Dremio)
# ============================================
# Dremio OSS hat keinen OIDC-Support (Enterprise only)
KEYCLOAK_CLIENT_ID_DREMIO=dremio
KEYCLOAK_CLIENT_SECRET_DREMIO=dremio-not-used

# ============================================
# Keycloak OIDC Client Secrets (Airflow)
# ============================================
KEYCLOAK_CLIENT_ID_AIRFLOW=airflow
KEYCLOAK_CLIENT_SECRET_AIRFLOW=CHANGE_ME_airflow_client_secret

# ============================================
# Airflow Configuration
# ============================================
# Fernet Key generieren mit: openssl rand -base64 32
AIRFLOW_FERNET_KEY=CHANGE_ME_generate_with_openssl_rand_base64_32
AIRFLOW_EXECUTOR=LocalExecutor

# ============================================
# Airflow Variables (werden automatisch via AIRFLOW_VAR_-Präfix gesetzt)
# Nach 'docker compose down -v' bleiben diese erhalten – kein manuelles Setzen nötig.
# ============================================
# Open-Meteo Standort
WEATHER_LATITUDE=52.59
WEATHER_LONGITUDE=13.35
WEATHER_LOCATION_KEY=berlin-reinickendorf
# Energy-Charts Gebotszone (DE-LU: verfügbar ab 01.10.2018)
ENERGY_CHARTS_BIDDING_ZONE=DE-LU
# Nessie Iceberg REST Catalog (für PyIceberg-DAGs wie energy_backfill_pyarrow)
NESSIE_URI=http://nessie:19120/iceberg

# ============================================
# AWS (falls verwendet)
# ============================================
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_REGION=us-east-1

# ============================================
# OpenMetadata Configuration
# ============================================
# Dedizierte PostgreSQL-Instanz für OpenMetadata (getrennt von shared postgres).
# Der Benutzername kann abweichen, der Default-Wert (openmetadata_user) wird
# im docker-compose.yml als Fallback verwendet wenn die Variable fehlt.
OPENMETADATA_DB_USER=openmetadata_user
OPENMETADATA_DB_PASSWORD=CHANGE_ME_openmetadata_db_password

# API-Konfiguration für Glossary-Ingest und API-Zugriffe.
# OM_URL wird von start.sh automatisch auf http://${EXTERNAL_HOST}:8585/api gesetzt.
OM_URL=http://localhost:8585/api
# OM_TOKEN muss manuell in der OM-UI generiert werden (Settings -> Users -> [User] -> Token)
OM_TOKEN=CHANGE_ME_openmetadata_api_token

# Keycloak OIDC Client für OpenMetadata (optional).
# Nur relevant wenn AUTHENTICATION_PROVIDER=custom-oidc aktiviert wird.
# Anleitung: Memory.md → "OpenMetadata OIDC Keycloak"
KEYCLOAK_CLIENT_ID_OPENMETADATA=openmetadata
KEYCLOAK_CLIENT_SECRET_OPENMETADATA=CHANGE_ME_openmetadata_client_secret

# ============================================
# Kaggle API Configuration (Spotify-Daten)
# ============================================
# Erforderlich für: spotify_kaggle_download DAG
# Anleitung: README.md → "🎵 Kaggle API Setup"
# 1. Kostenlos registrieren auf https://www.kaggle.com
# 2. API-Token generieren: Settings → API → "Create New API Token"
# 3. kaggle.json öffnen und Werte hier eintragen:
KAGGLE_USERNAME=YOUR_KAGGLE_USERNAME
KAGGLE_API_KEY=KGAT_YOUR_API_TOKEN_HERE

SPOTIFY_CLIENT_ID=YOUR_SPOTIFY_CLIENT_ID_HERE
SPOTIFY_CLIENT_SECRET=YOUR_SPOTIFY_CLIENT_SECRETHERE